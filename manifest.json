{
    "manifest_version": 3,
    "name": "Table to Excel Exporter",
    "version": "1.0",
    "description": "Extracts data from a specific table and downloads it as an Excel file.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "assets/TableExtractor.png",
        "48": "assets/TableExtractor.png",
        "128": "assets/TableExtractor.png"
    }
}